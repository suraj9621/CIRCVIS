# CIRCVIS Environment Configuration
# Copy this file to .env and fill in your values

# Flask/FastAPI
DEBUG=True
LOG_LEVEL=INFO

# Models Configuration
MODELS_DIR=./models
DATA_DIR=./data/processed
USE_MOCK_MODELS=False

# Model Service
ENSEMBLE_WEIGHTS_FILE=./models/ensemble_weights.pkl
RESNET50_MODEL_PATH=./models/resnet50.keras
MOBILENET_MODEL_PATH=./models/mobilenetv2.keras
EFFICIENTNET_MODEL_PATH=./models/efficientnetb0.keras

# Image Processing
IMAGE_SIZE=224
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_FORMATS=jpg,jpeg,png,gif,bmp

# Inference
BATCH_SIZE=32
NUM_WORKERS=4
GPU_MEMORY_FRACTION=0.8

# API Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
API_VERSION=v1
API_TITLE=CIRCVIS API

# Database (optional)
# DATABASE_URL=sqlite:///./circvis.db

# External Services (optional)
# REDIS_URL=redis://localhost:6379
# SENTRY_DSN=https://...

# Deployment
ENVIRONMENT=development  # development, staging, production
SECRET_KEY=your-secret-key-here
